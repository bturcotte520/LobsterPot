# Bridge
LOBSTERPOT_BRIDGE_PORT=3000
LOBSTERPOT_PUBLIC_BASE_URL=http://127.0.0.1:3000
LOBSTERPOT_DB_PATH=./apps/bridge/data/lobsterpot.db

# Optional direct APNs for self-built clones
LOBSTERPOT_APNS_TEAM_ID=
LOBSTERPOT_APNS_KEY_ID=
LOBSTERPOT_APNS_BUNDLE_ID=
LOBSTERPOT_APNS_PRIVATE_KEY_PATH=

# Optional hosted relay
LOBSTERPOT_PUSH_RELAY_URL=http://127.0.0.1:3100
LOBSTERPOT_PUSH_RELAY_TOKEN=

# Push relay
LOBSTERPOT_RELAY_PORT=3100
LOBSTERPOT_RELAY_ADMIN_TOKEN=dev-relay-token
LOBSTERPOT_RELAY_DB_PATH=./apps/push-relay/data/relay.db

# APNs (set these to enable real push on the relay)
LOBSTERPOT_APNS_TEAM_ID=
LOBSTERPOT_APNS_KEY_ID=
LOBSTERPOT_APNS_BUNDLE_ID=com.lobsterpot.app
LOBSTERPOT_APNS_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
LOBSTERPOT_APNS_PRODUCTION=false
